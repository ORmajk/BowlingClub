<Page x:Class="BowlingClub.Pages.EventEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BowlingClub.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="950" d:DesignWidth="850"
      Title="EventEditPage">

    <Grid Background="#1E1E1E">
        <Border Width="480" Height="680" Padding="20" Background="#2A2A2A" CornerRadius="10"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>

                <TextBlock x:Name="tbTitle" 
                               Text="Добавление игры" 
                               FontSize="26" 
                               Foreground="White" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,20"/>

                <TextBlock Text="Название игры" Foreground="White" Margin="0,0,0,5"/>
                <TextBox x:Name="txtEventName" Height="35" FontSize="18" Padding="3" Margin="0,0,0,15"/>

                <TextBlock Text="Дата проведения" Foreground="White" Margin="0,0,0,5"/>
                <DatePicker x:Name="dpEventDate" Height="35" FontSize="18" Margin="0,0,0,15"/>

                <TextBlock Text="Номер дорожки" Foreground="White" Margin="0,0,0,5"/>
                <ComboBox x:Name="cbLane" Height="35" FontSize="18" Margin="0,0,0,15" DisplayMemberPath="LaneNumber" SelectedValuePath="Id"/>

                <TextBlock Text="Описание" Foreground="White" Margin="0,0,0,5"/>
                <TextBox x:Name="txtDescription" Height="70" FontSize="16" Padding="3" Margin="0,0,0,15" TextWrapping="Wrap" AcceptsReturn="True"/>

                <TextBlock Text="Записанные клиенты" Foreground="White" Margin="0,0,0,5"/>
                <Border BorderThickness="1" BorderBrush="#444444" CornerRadius="5" Height="110" Margin="0,0,0,20" Background="#1E1E1E">
                    <ListBox x:Name="lbClients" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding FullName}" 
                                              IsChecked="{Binding IsSelected}" 
                                              Foreground="White" 
                                              FontSize="16" 
                                              Margin="5,2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Button Content="Сохранить" 
                            Height="40" 
                            Background="#3A8DFF" 
                            Foreground="White" 
                            FontWeight="Bold" 
                            Margin="0,0,0,10" 
                            Click="Save_Click"/>

                <Button Content="Отмена" 
                            Height="40" 
                            Background="#444444" 
                            Foreground="White" 
                            FontWeight="Bold" 
                            Click="Cancel_Click"/>

                <TextBlock x:Name="lblError" 
                               Foreground="OrangeRed" 
                               FontSize="14" 
                               Margin="0,15,0,0" 
                               TextWrapping="Wrap"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>
