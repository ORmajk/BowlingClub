<Page x:Class="BowlingClub.Pages.BookingEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BowlingClub.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="950" d:DesignWidth="850"
      Title="BookingEditPage">

    <Grid Background="#1E1E1E">
        <Border Width="620" Height="880" Padding="20" Background="#2A2A2A" CornerRadius="10"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>

                <TextBlock x:Name="tbTitle" Text="Добавление брони" FontSize="26" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <!-- Основные поля бронирования -->
                <TextBlock Text="Номер бронирования" Foreground="White" Margin="0,0,0,5"/>
                <TextBox x:Name="txtBookingNumber" Height="35" FontSize="16" Padding="3" Margin="0,0,0,10"/>

                <TextBlock Text="Клиент" Foreground="White" Margin="0,0,0,5"/>
                <ComboBox x:Name="cbClient" Height="35" FontSize="16" Margin="0,0,0,10" DisplayMemberPath="FullName" SelectedValuePath="Id"/>

                <TextBlock Text="Дорожка" Foreground="White" Margin="0,0,0,5"/>
                <ComboBox x:Name="cbLane" Height="35" FontSize="16" Margin="0,0,0,10" DisplayMemberPath="LaneNumber" SelectedValuePath="Id"/>

                <TextBlock Text="Дата и время начала" Foreground="White" Margin="0,0,0,5"/>
                <DatePicker x:Name="dpStartDate" Height="35" FontSize="16" Margin="0,0,0,10"/>

                <TextBlock Text="Длительность (минут)" Foreground="White" Margin="0,0,0,5"/>
                <TextBox x:Name="txtDuration" Height="35" FontSize="16" Padding="3" Margin="0,0,0,10"/>

                <!-- Статус бронирования -->
                <TextBlock Text="Статус бронирования:" Foreground="White" FontSize="14" Margin="0,0,0,5"/>
                <ComboBox x:Name="cbStatus" Height="35" FontSize="16" Margin="0,0,0,10"/>

                <!-- Способ оплаты -->
                <TextBlock Text="Способ оплаты:" Foreground="White" FontSize="14" Margin="0,0,0,5"/>
                <ComboBox x:Name="cbPaymentMethod" Height="35" FontSize="16" Margin="0,0,0,15"/>

                <!-- Поля быстрого добавления услуги с подписями -->
                <Grid Margin="0,0,0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="75"/>
                    </Grid.ColumnDefinitions>

                    <!-- Строка 0: Подписи к полям -->
                    <TextBlock Text="Название услуги" Foreground="White" FontSize="12" Margin="0,0,5,3" Grid.Row="0" Grid.Column="0"/>
                    <TextBlock Text="Кол-во" Foreground="White" FontSize="12" Margin="0,0,5,3" Grid.Row="0" Grid.Column="1"/>
                    <TextBlock Text="Цена" Foreground="White" FontSize="12" Margin="0,0,5,3" Grid.Row="0" Grid.Column="2"/>

                    <!-- Строка 1: Поля ввода и кнопки -->
                    <ComboBox x:Name="cbItemName" Height="30" Margin="0,0,5,0" FontSize="14" 
                              Grid.Row="1" Grid.Column="0" SelectionChanged="cbItemName_SelectionChanged"/>

                    <TextBox x:Name="txtItemQty" ToolTip="Кол-во" Text="1"
                             Height="30" Margin="0,0,5,0" FontSize="14" Padding="2" Grid.Row="1" Grid.Column="1"/>

                    <TextBox x:Name="txtItemPrice" ToolTip="Цена" IsReadOnly="True" Background="#EAEAEA"
                             Height="30" Margin="0,0,5,0" FontSize="14" Padding="2" Grid.Row="1" Grid.Column="2"/>

                    <Button Content="Добавить" Click="AddItem_Click" Background="#3A8DFF" Foreground="White" 
                            FontWeight="Bold" Height="30" Margin="0,0,5,0" Grid.Row="1" Grid.Column="3" VerticalAlignment="Bottom"/>

                    <Button Content="Удалить" Click="RemoveSelectedGridItem_Click" Background="Firebrick" Foreground="White" 
                            FontWeight="Bold" Height="30" Grid.Row="1" Grid.Column="4" VerticalAlignment="Bottom"/>
                </Grid>

                <!-- Таблица услуг чека -->
                <DataGrid x:Name="dgBookingItems" AutoGenerateColumns="False" Height="110" Margin="0,0,0,10" IsReadOnly="True" Background="#1E1E1E" RowHeight="30" FontSize="14">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Услуга" Binding="{Binding ItemName}" Width="*"/>
                        <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="60"/>
                        <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:F2}}" Width="80"/>
                        <DataGridTextColumn Header="Всего" Binding="{Binding Total, StringFormat={}{0:F2}}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Итоговая автоматическая сумма -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
                    <TextBlock Text="Итого к оплате: " Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <TextBlock x:Name="lblTotalAmount" Text="0,00 руб." Foreground="#3A8DFF" FontSize="18" FontWeight="Bold"/>
                </StackPanel>

                <!-- Кнопки управления -->
                <Button Content="Сохранить" Height="40" Background="#3A8DFF" Foreground="White" FontWeight="Bold" Margin="0,0,0,10" Click="Save_Click"/>
                <Button Content="Отмена" Height="40" Background="#444444" Foreground="White" FontWeight="Bold" Click="Cancel_Click"/>

                <TextBlock x:Name="lblError" Foreground="OrangeRed" FontSize="14" Margin="0,10,0,0" TextWrapping="Wrap"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>
