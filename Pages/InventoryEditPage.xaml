<Page x:Class="BowlingClub.Pages.InventoryEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BowlingClub.Pages"
      mc:Ignorable="d" 
       d:DesignHeight="700" d:DesignWidth="800"
      Title="InventoryEditPage">

    <Grid Background="#1E1E1E">
        <!-- Карточка в стиле формы Login -->
        <Border Width="480" Height="620" Padding="20" Background="#2A2A2A" CornerRadius="10"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Заголовок страницы -->
                    <TextBlock x:Name="tbTitle" 
                               Text="Добавление инвентаря" 
                               FontSize="26" 
                               Foreground="White" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,20"/>

                    <!-- Поле: Название -->
                    <TextBlock Text="Название" Foreground="White" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtItemName" Height="35" FontSize="18" Padding="3" Margin="0,0,0,15"/>

                    <!-- Поле: Тип инвентаря -->
                    <TextBlock Text="Тип инвентаря" Foreground="White" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtType" Height="35" FontSize="18" Padding="3" Margin="0,0,0,15" ToolTip="Например: Шары, Обувь"/>

                    <!-- Поле: Размер или Вес -->
                    <TextBlock Text="Размер / Вес" Foreground="White" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtSizeOrWeight" Height="35" FontSize="18" Padding="3" Margin="0,0,0,15"/>

                    <!-- Поле: Количество -->
                    <TextBlock Text="Количество (шт.)" Foreground="White" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtQuantity" Height="35" FontSize="18" Padding="3" Margin="0,0,0,15"/>

                    <!-- Поле: Статус (из БД) -->
                    <TextBlock Text="Статус инвентаря" Foreground="White" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cbStatus" Height="35" FontSize="18" Margin="0,0,0,25" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                    <!-- Кнопка: Сохранить -->
                    <Button Content="Сохранить" 
                            Height="40" 
                            Background="#3A8DFF" 
                            Foreground="White" 
                            FontWeight="Bold" 
                            Margin="0,0,0,10" 
                            Click="Save_Click"/>

                    <!-- Кнопка: Отмена -->
                    <Button Content="Отмена" 
                            Height="40" 
                            Background="#444444" 
                            Foreground="White" 
                            FontWeight="Bold" 
                            Click="Cancel_Click"/>

                    <!-- ПОЛЕ ВЫВОДА ОШИБОК -->
                    <TextBlock x:Name="lblError" 
                               Foreground="OrangeRed" 
                               FontSize="14" 
                               Margin="0,15,0,0" 
                               TextWrapping="Wrap"/>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
