<Page x:Class="BowlingClub.Pages.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BowlingClub.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Login">

    <Grid Background="#1E1E1E">
        <Border Width="480" Height="380" Padding="20" Background="#2A2A2A" CornerRadius="10"
        VerticalAlignment="Center" HorizontalAlignment="Center">

            <StackPanel>
                <TextBlock Text="Вход в систему"
                   FontSize="26"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 20"/>

                <TextBlock Text="Логин" Foreground="White" Margin="0 0 0 5"/>
                <TextBox x:Name="tbLogin"
                 Height="35"
                 Margin="0 0 0 15" FontSize="24" Text="admin"/>

                <TextBlock Text="Пароль" Foreground="White" Margin="0 0 0 5"/>
                <PasswordBox x:Name="pbPassword"
                     Height="35"
                     Margin="0 0 0 25" FontSize="24"/>

                <Button Content="Войти"
                Height="40"
                Background="#3A8DFF"
                Foreground="White"
                FontWeight="Bold"
                Margin="0 0 0 15" Click="Button_Click"/>

                <Button Content="Регистрация"
                Height="40"
                Background="#3A8DFF"
                Foreground="White"
                FontWeight="Bold" Click="Button_Click_1"/>

                <TextBlock x:Name="lblError"
                   Foreground="OrangeRed"
                   FontSize="14"
                   Margin="0 15 0 0"
                   TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
