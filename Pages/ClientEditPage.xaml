<Page x:Class="BowlingClub.Pages.ClientEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BowlingClub.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="800"
      Title="ClientEditPage">

    <Grid Background="#1E1E1E">
        <Border Width="480" Height="580" Padding="20" Background="#2A2A2A" CornerRadius="10"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <TextBlock x:Name="tbTitle" 
                               Text="Добавление клиента" 
                               FontSize="26" 
                               Foreground="White" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,20"/>

                    <TextBlock Text="ФИО Клиента" Foreground="White" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtFullName" Height="35" FontSize="18" Padding="3" Margin="0,0,0,15"/>

                    <!-- Поле: Телефон -->
                    <TextBlock Text="Номер телефона" Foreground="White" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtPhone" Height="35" FontSize="18" Padding="3" Margin="0,0,0,15"/>

                    <TextBlock Text="Электронная почта (Email)" Foreground="White" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtEmail" Height="35" FontSize="18" Padding="3" Margin="0,0,0,15"/>

                    <TextBlock Text="Бонусные баллы" Foreground="White" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtPoints" Height="35" FontSize="18" Padding="3" Margin="0,0,0,20"/>

                    <CheckBox x:Name="chbSubscribed" 
                              Content="Подписка на рассылку ИИ" 
                              Foreground="White" 
                              FontSize="16" 
                              Margin="0,0,0,25" 
                              VerticalContentAlignment="Center"/>

                    <Button Content="Сохранить" 
                            Height="40" 
                            Background="#3A8DFF" 
                            Foreground="White" 
                            FontWeight="Bold" 
                            Margin="0,0,0,10" 
                            Click="Save_Click"/>

                    <Button Content="Отмена" 
                            Height="40" 
                            Background="#444444" 
                            Foreground="White" 
                            FontWeight="Bold" 
                            Click="Cancel_Click"/>

                    <TextBlock x:Name="lblError" 
                               Foreground="OrangeRed" 
                               FontSize="14" 
                               Margin="0,15,0,0" 
                               TextWrapping="Wrap"/>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
