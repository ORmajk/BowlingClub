<Page x:Class="BowlingClub.Pages.ReceiptPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BowlingClub.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="1500" d:DesignWidth="600"
      Title="Чек бронирования"
    >

    <Grid Background="#1E1E1E">
        <!-- Контейнер для чека -->
        <Border Width="550" Height="900" Padding="25" Background="White" CornerRadius="5"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                BorderBrush="#DDD" BorderThickness="1">

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- Заголовок чека -->
                    <Border Background="#2A2A2A" CornerRadius="5" Padding="10" Margin="0,0,0,20">
                        <TextBlock Text="ЧЕК ОПЛАТЫ" FontSize="22" FontWeight="Bold" 
                                   Foreground="White" HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Информация о бронировании -->
                    <Border Background="#F0F0F0" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="ИНФОРМАЦИЯ О БРОНИРОВАНИИ" FontWeight="Bold" 
                                       FontSize="14" Margin="0,0,0,5" Foreground="#333"/>

                            <Grid Margin="0,5,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Номер брони:" Foreground="#666" Grid.Row="0" Grid.Column="0"/>
                                <TextBlock Text="{Binding BookingNumber}" FontWeight="SemiBold" Grid.Row="0" Grid.Column="1"/>

                                <TextBlock Text="Клиент:" Foreground="#666" Grid.Row="1" Grid.Column="0"/>
                                <TextBlock Text="{Binding Clients.FullName}" FontWeight="SemiBold" Grid.Row="1" Grid.Column="1"/>

                                <TextBlock Text="Дорожка:" Foreground="#666" Grid.Row="2" Grid.Column="0"/>
                                <TextBlock Text="{Binding Lanes.LaneNumber}" FontWeight="SemiBold" Grid.Row="2" Grid.Column="1"/>

                                <TextBlock Text="Дата и время:" Foreground="#666" Grid.Row="3" Grid.Column="0"/>
                                <TextBlock Text="{Binding StartTime, StringFormat=dd.MM.yyyy HH:mm}" FontWeight="SemiBold" Grid.Row="3" Grid.Column="1"/>

                                <TextBlock Text="Длительность:" Foreground="#666" Grid.Row="4" Grid.Column="0"/>
                                <TextBlock Text="{Binding DurationMinutes}" FontWeight="SemiBold" Grid.Row="4" Grid.Column="1"/>

                                <TextBlock Text="Кол-во позиций:" Foreground="#666" Grid.Row="5" Grid.Column="0"/>
                                <TextBlock Text="{Binding ItemsCount}" FontWeight="SemiBold" Grid.Row="5" Grid.Column="1"/>

                                <TextBlock Text="Статус:" Foreground="#666" Grid.Row="6" Grid.Column="0"/>
                                <TextBlock Text="{Binding Status}" FontWeight="SemiBold" Grid.Row="6" Grid.Column="1">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="Green"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Оплачен">
                                                    <Setter Property="Foreground" Value="Green"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Создан">
                                                    <Setter Property="Foreground" Value="Orange"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Отменен">
                                                    <Setter Property="Foreground" Value="Red"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Таблица услуг -->
                    <Border Background="#F0F0F0" CornerRadius="5" Padding="10" Margin="0,0,0,15" Height="174">
                        <StackPanel>
                            <TextBlock Text="УСЛУГИ" FontWeight="Bold" FontSize="14" 
                                       Margin="0,0,0,10" Foreground="#333"/>

                            <DataGrid x:Name="dgReceiptItems" AutoGenerateColumns="False" 
                                      Height="200" IsReadOnly="True" 
                                      BorderBrush="#DDD" BorderThickness="1"
                                      GridLinesVisibility="Horizontal"
                                      RowHeight="30" FontSize="13"
                                      HeadersVisibility="Column"
                                      Background="White">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Наименование" Binding="{Binding ItemName}" 
                                                        Width="*" FontWeight="SemiBold"/>

                                    <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" 
                                                        Width="60">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:F2} руб.}" 
                                                        Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Сумма" Binding="{Binding Total, StringFormat={}{0:F2} руб.}" 
                                                        Width="100" FontWeight="Bold">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                    <Border Background="#F9F9F9" CornerRadius="5" Padding="15" Margin="0,0,0,15" Height="296">
                        <StackPanel>
                            <TextBlock Text="📱 QR-КОД ДЛЯ ОПЛАТЫ" FontWeight="Bold" FontSize="14" 
                                       Margin="0,0,0,10" Foreground="#333" HorizontalAlignment="Center"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- QR-код -->
                                <Border Grid.Column="1" Background="White" CornerRadius="5" 
                                        BorderBrush="#DDD" BorderThickness="1" Padding="10">
                                    <Image x:Name="imgQr" Width="180" Height="180" 
                                           Stretch="Uniform"/>
                                </Border>
                            </Grid>

                            <TextBlock Text="Отсканируйте QR-код для оплаты" 
                                       FontSize="11" Foreground="#666" 
                                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            <TextBlock Text="или для просмотра деталей чека" 
                                       FontSize="11" Foreground="#999" 
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Итоговая сумма -->
                    <Border Background="#2A2A2A" CornerRadius="5" Padding="15" Margin="0,0,0,20" Height="55">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="ИТОГО К ОПЛАТЕ:" FontSize="18" FontWeight="Bold" 
                                       Foreground="White" Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:F2}}" 
                                       FontSize="24" FontWeight="Bold" Foreground="#FFD700" 
                                       Grid.Column="1" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="руб." FontSize="18" FontWeight="Bold" 
                                       Foreground="#FFD700" Grid.Column="2" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Информация об оплате -->
                    <Border Background="#F0F0F0" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                        <StackPanel>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Способ оплаты:" Foreground="#666" Grid.Row="0" Grid.Column="0"/>
                                <TextBlock Text="{Binding PaymentMethod}" FontWeight="SemiBold" Grid.Row="0" Grid.Column="1"/>

                                <TextBlock Text="Дата оплаты:" Foreground="#666" Grid.Row="1" Grid.Column="0"/>
                                <TextBlock Text="{Binding StartTime, StringFormat=dd.MM.yyyy HH:mm}" 
                                           FontWeight="SemiBold" Grid.Row="1" Grid.Column="1"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки управления -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                        <Button Content="PDF" Click="ExportToPdf_Click"
                                Background="#FF5722" Foreground="White"  FontWeight="Bold" 
                                FontSize="14" Padding="20,8" Margin="0,0,10,0"
                                Cursor="Hand" ToolTip="Ctrl+P">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Content="Закрыть" Click="Close_Click" 
                                Background="#666" Foreground="White" FontWeight="Bold" 
                                FontSize="14" Padding="20,8" Cursor="Hand" ToolTip="Esc">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
