<Page x:Class="BowlingClub.Pages.Register"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BowlingClub.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="660" d:DesignWidth="800"
      Title="Register">

    <Grid Background="#1E1E1E">
        <Border Width="520" Height="630" Padding="22" Background="#2A2A2A" CornerRadius="10"
                VerticalAlignment="Center" HorizontalAlignment="Center">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="Регистрация"
                               FontSize="26"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 18"/>

                    <TextBlock Text="ФИО" Foreground="White" Margin="0 0 0 5" FontSize="16"/>
                    <TextBox x:Name="tbFullName" Height="36" Margin="0 0 0 12" FontSize="16"/>

                    <TextBlock Text="Email" Foreground="White" Margin="0 0 0 5" FontSize="16"/>
                    <TextBox x:Name="tbEmail" Height="36" Margin="0 0 0 12" FontSize="16"/>

                    <TextBlock Text="Логин" Foreground="White" Margin="0 0 0 5" FontSize="16"/>
                    <TextBox x:Name="tbLogin" Height="36" Margin="0 0 0 12" FontSize="16"/>

                    <TextBlock Text="Телефон" Foreground="White" Margin="0 0 0 5" FontSize="16"/>
                    <TextBox x:Name="tbPhone" Height="36" Margin="0 0 0 12" FontSize="16"/>

                    <TextBlock Text="Пароль" Foreground="White" Margin="0 0 0 5" FontSize="16"/>
                    <PasswordBox x:Name="pbPassword" Height="36" Margin="0 0 0 12" FontSize="16"/>

                    <TextBlock Text="Подтвердите пароль" Foreground="White" Margin="0 0 0 5" FontSize="16"/>
                    <PasswordBox x:Name="pbConfirm" Height="36" Margin="0 0 0 18" FontSize="16"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 10">
                        <Button Content="Зарегистрироваться"
                                Width="182" Height="40"
                                FontSize="16"
                                Background="#3A8DFF" Foreground="White" FontWeight="Bold"
                                Click="Register_Click" Margin="0,0,12,0"/>
                        <Button Content="Назад к входу"
                                Width="140" Height="40"
                                FontSize="16"
                                Background="#444" Foreground="White"
                                Click="BackToLogin_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="lblError"
                               Foreground="OrangeRed"
                               FontSize="14"
                               Margin="0 10 0 0"
                               TextWrapping="Wrap"/>

                    <TextBlock x:Name="lblSuccess"
                               Foreground="#7CFC00"
                               FontSize="14"
                               Margin="0 10 0 0"
                               TextWrapping="Wrap"/>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
